# Environment Variables

# MongoDB
MONGODB_URI=mongodb://localhost:27017/nearbyStores
# Or use MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/nearbyStores

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Brevo (Email Service)
BREVO_API_KEY=your-brevo-api-key-here
BREVO_SENDER_EMAIL=noreply@nearbystores.com
BREVO_SENDER_NAME=NearbyStores

# Firebase (for OTP Authentication)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# Geolocation Settings
PROXIMITY_RADIUS_METERS=500
PROXIMITY_COOLDOWN_HOURS=24
