# Backend Environment Variables
# For Render: set these in the Render dashboard → Environment tab.
# For local dev: copy this to .env and update values.

# MongoDB — REQUIRED
# Use MongoDB Atlas (free tier): mongodb+srv://user:pass@cluster.mongodb.net/nearbyStores
MONGODB_URI=mongodb://localhost:27017/nearbyStores

# JWT Secret — use a long random string in production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS) — set to your Vercel URL in production
# Example: https://nearbystores.vercel.app
FRONTEND_URL=http://localhost:3000

# Gmail OTP — REQUIRED for email verification
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
BREVO_SENDER_NAME=NearbyStores

# Geolocation
PROXIMITY_RADIUS_METERS=500
PROXIMITY_COOLDOWN_HOURS=24

# Razorpay (Test Mode)
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_key_secret_here

# Admin Registration Secret Key
ADMIN_SECRET=admin-secret-2026

# Firebase
FIREBASE_PROJECT_ID=nearbystores-2fcc7
